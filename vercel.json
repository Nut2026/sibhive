{
  "crons": [
    { "path": "/api/recalculate-scores", "schedule": "0 0 * * *" },
    { "path": "/api/send-scheduled-notifications", "schedule": "0 8,16 * * *" },
    { "path": "/api/weekly-summary", "schedule": "0 9 * * 1" },
    { "path": "/api/process-deletions", "schedule": "0 1 * * *" }
  ],
  "headers": [{ "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "X-Frame-Options", "value": "DENY" }, { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }, { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }]}]
}
