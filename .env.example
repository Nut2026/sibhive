# Supabase client configuration
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
SUPABASE_PROJECT_REF_STAGING=your-staging-project-ref
SUPABASE_PROJECT_REF_PRODUCTION=your-production-project-ref

# Server-side AI and email configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_TERRA_MODEL=gpt-5.6-terra
OPENAI_VISION_MODEL=
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@example.com

# Server-side security configuration
JWT_SECRET=replace-with-a-local-development-secret
SUPABASE_JWT_SECRET=replace-with-your-supabase-jwt-secret
ENCRYPTION_KEY=replace-with-a-local-development-key
CRON_SECRET=replace-with-a-long-random-secret

# Feature flags
VITE_FEATURE_AI_GENERATION=true
VITE_FEATURE_DAILY_PROMPTS=true
VITE_FEATURE_POLLEN_GARDEN=false
VITE_FEATURE_CHAT=false
VITE_FEATURE_NOTIFICATIONS=false
VITE_FEATURE_WEEKLY_EMAIL=false
VITE_FEATURE_HEALING_CHAMBER=false
VITE_FEATURE_AUDIO_RECORDING=false
