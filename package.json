{
  "name": "sibhive",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "vercel-functions"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "npm run lint && npm run typecheck && npm run test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "cd apps/web && npm run test:e2e",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "supabase": "^2.109.1",
    "turbo": "^2.5.0"
  }
}
